# Copy to .env and change values
APP_NAME=trade-finance-m1
DEBUG=False
DATABASE_URL=sqlite:///./trade_finance.db

# JWT
JWT_SECRET_KEY=replace-this-with-a-secure-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Bootstrap admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=AdminPass123!

AWS_ACCESS_KEY_ID=xxxx
AWS_SECRET_ACCESS_KEY=xxxx
AWS_REGION=ap-south-1
AWS_S3_BUCKET=trade-finance-docs
